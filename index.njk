---
layout: base.njk
title: Il primo sito in Italia che parla di tamburello
---

<section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-overlay"></div>
    <div class="hero-content container">
        <h1>Tamburello<span>360</span></h1>
        <p class="hero-subtitle">Il primo sito in Italia interamente dedicato al tamburello</p>
        <div class="hero-actions">
            <a href="/blog/" class="btn btn-primary">Leggi il Blog</a>
            <a href="/classifiche/" class="btn btn-secondary">Vedi Classifiche</a>
        </div>
    </div>

    {%- if collections.classificheSerieA.length > 0 -%}
    {%- set primaClassifica = collections.classificheSerieA[0] -%}
    {%- if primaClassifica.data.teams.length > 0 -%}
    <div class="hero-classifica">
        <div class="hero-classifica-title">📊 {{ primaClassifica.data.serie }} {{ primaClassifica.data.year }}</div>
        <div class="mini-podio">
            {%- for team in primaClassifica.data.teams | limit(3) -%}
            <div class="mini-row">
                <span class="mini-pos p{{ loop.index }}">{{ loop.index }}</span>
                <span class="mini-name">{{ team.name }}</span>
                <span class="mini-pts">{{ team.points }} pt</span>
            </div>
            {%- endfor -%}
        </div>
        <a href="/classifiche/" class="hero-classifica-link">Classifica completa →</a>
    </div>
    {%- endif -%}
    {%- endif -%}
</section>

<section class="section section-light">
    <div class="container">
        <div class="section-header">
            <div>
                <span class="section-label">Dal Blog</span>
                <h2 class="section-title">Ultimi Articoli</h2>
            </div>
            <a href="/blog/" class="view-all">Tutti gli articoli →</a>
        </div>
        <div class="articles-grid">
            {%- for post in collections.blogVisible | limit(3) -%}
            <a href="{{ post.url }}" class="article-card">
                <div class="article-image-wrap">
                    {%- if post.data.image -%}
                    <img src="{{ post.data.image }}" alt="{{ post.data.title }}" class="article-image" loading="lazy">
                    {%- else -%}
                    <div style="width:100%;height:100%;background:var(--gray-100);display:flex;align-items:center;justify-content:center;font-size:3rem;">🏓</div>
                    {%- endif -%}
                    <span class="article-category-badge">{{ post.data.category }}</span>
                </div>
                <div class="article-body">
                    <div class="article-meta">
                        <span>{{ post.data.date | shortDate }}</span>
                        {%- if post.data.reading_time -%}
                        <span class="article-meta-dot">·</span>
                        <span>⏱ {{ post.data.reading_time }} min</span>
                        {%- endif -%}
                    </div>
                    <h3 class="article-title">{{ post.data.title }}</h3>
                    <p class="article-excerpt">{{ post.data.excerpt or post.templateContent | striptags | truncate(130) }}</p>
                </div>
            </a>
            {%- else -%}
            <div class="empty-state"><p>Nessun articolo ancora. Aggiungili dal pannello admin!</p></div>
            {%- endfor -%}
        </div>
    </div>
</section>

<div class="stats-bar">
    <div class="container">
        <div class="stats-inner">
            <div class="stat-item">
                <div class="stat-number">{{ collections.teamDatabase.length }}</div>
                <div class="stat-label">Squadre</div>
            </div>
            <div class="stat-item">
                <div class="stat-number">{{ collections.blog.length }}</div>
                <div class="stat-label">Articoli</div>
            </div>
            <div class="stat-item">
                <div class="stat-number">{{ collections.partiteEnriched.length }}</div>
                <div class="stat-label">Partite</div>
            </div>
        </div>
    </div>
</div>

{%- if collections.partiteRecenti.length > 0 -%}
<section class="section">
    <div class="container">
        <div class="section-header">
            <div>
                <span class="section-label">Ultimo risultato</span>
                <h2 class="section-title">Risultati Recenti</h2>
            </div>
            <a href="/partite/" class="view-all">Tutte le partite →</a>
        </div>
        <div class="risultati-grid">
            {%- for match in collections.partiteRecenti | limit(4) -%}
            <div class="risultato-card">
                <div class="risultato-header">
                    <span class="risultato-serie">Serie A</span>
                    <span class="risultato-data">{{ match.date_day_label }}</span>
                </div>
                <div class="match-display">
                    <div class="match-team {% if match.gol_casa > match.gol_ospite %}winner{% endif %}">{{ match.home_team.name }}</div>
                    <div class="match-score">{{ match.gol_casa }} - {{ match.gol_ospite }}</div>
                    <div class="match-team {% if match.gol_ospite > match.gol_casa %}winner{% endif %}">{{ match.away_team.name }}</div>
                </div>
            </div>
            {%- endfor -%}
        </div>
    </div>
</section>
{%- endif -%}
