---
layout: base.njk
title: Squadre
---

<div class="page-header">
    <h1>Squadre</h1>
</div>

<section class="section">
    <div class="container">
        <div class="squadre-grid" id="squadreGrid">
            {%- for squadra in collections.teamDatabase -%}
            <div class="squadra-card">
                {%- if squadra.logo -%}
                <img src="{{ squadra.logo }}" alt="{{ squadra.name }}" class="squadra-logo">
                {%- endif -%}
                <h3 class="squadra-name">{{ squadra.name }}</h3>
                <span class="squadra-badge">Serie A</span>
                <div class="squadra-info">
                    <strong>Codice</strong> {{ squadra.team_code }}
                </div>
                <div class="squadra-info">
                    <strong>📍</strong> {{ squadra.city }}
                </div>
                {%- if squadra.description -%}
                <p class="squadra-desc">{{ squadra.description }}</p>
                {%- endif -%}
                {%- if squadra.website -%}
                <a href="{{ squadra.website }}" target="_blank" rel="noopener" class="squadra-link">Sito Web →</a>
                {%- endif -%}
            </div>
            {%- else -%}
            <div class="empty-state"><p>Nessuna squadra ancora. Aggiungile dal pannello admin!</p></div>
            {%- endfor -%}
        </div>
    </div>
</section>
